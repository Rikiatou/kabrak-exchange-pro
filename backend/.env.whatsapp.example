# Variables d'environnement pour WhatsApp Business API (Meta)
# Ajouter ces variables sur Railway dans les settings du projet

# Meta App Configuration
META_APP_ID=votre_app_id_meta
META_APP_SECRET=votre_app_secret_meta

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=votre_phone_number_id
WHATSAPP_ACCESS_TOKEN=votre_access_token_whatsapp

# Optionnel: Webhook URL pour recevoir les messages
WHATSAPP_WEBHOOK_VERIFY_TOKEN=votre_webhook_token
WHATSAPP_WEBHOOK_URL=https://kabrak-exchange-pro-production.up.railway.app/webhooks/whatsapp
